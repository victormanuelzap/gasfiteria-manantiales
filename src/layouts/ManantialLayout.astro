  <style>
    /* =========================================================
   TEMA BASE MANANTIAL
   ---------------------------------------------------------
   Variables globales del sitio:
   - Colores
   - sombras
   - radios
   - ancho máximo
   - altura base del header
   ========================================================= */
.manantial-theme {
  --mnl-bg: #081327;
  --mnl-bg-soft: #0c1a35;
  --mnl-bg-card: rgba(255, 255, 255, 0.08);
  --mnl-surface: #ffffff;
  --mnl-text: #ffffff;
  --mnl-text-soft: rgba(255, 255, 255, 0.78);
  --mnl-text-dark: #14213d;
  --mnl-border: rgba(255, 255, 255, 0.1);
  --mnl-border-soft: rgba(255, 255, 255, 0.07);
  --mnl-primary: #245be8;
  --mnl-primary-hover: #1b49bc;
  --mnl-accent: #ffd400;
  --mnl-accent-2: #ffea70;
  --mnl-success: #00d26a;
  --mnl-shadow: 0 12px 38px rgba(0, 0, 0, 0.25);
  --mnl-radius: 20px;
  --mnl-radius-sm: 14px;
  --mnl-container: 1200px;
  --mnl-header-h: 82px;

  color: var(--mnl-text-dark);
  background: var(--mnl-surface);
  min-height: 100vh;
}

/* Hace que todo el tema use box-sizing consistente */
.manantial-theme,
.manantial-theme * {
  box-sizing: border-box;
}

/* Imágenes responsivas por defecto */
.manantial-theme img {
  max-width: 100%;
  display: block;
}

/* Transiciones suaves generales para links */
.manantial-theme a {
  color: inherit;
  text-decoration: none;
  transition:
    color 0.25s ease,
    background-color 0.25s ease,
    border-color 0.25s ease,
    transform 0.25s ease,
    opacity 0.25s ease;
}

/* Hover general de links */
.manantial-theme a:hover {
  color: var(--mnl-accent);
}

/* Altura mínima del contenido principal */
.manantial-theme main {
  min-height: 45vh;
}

/* Contenedor general del sitio */
.manantial-theme .container {
  width: min(100% - 40px, var(--mnl-container));
  margin-inline: auto;
}

/* Link de accesibilidad para saltar al contenido */
.manantial-theme .skip-link {
  position: absolute;
  left: 12px;
  top: -44px;
  z-index: 999;
  padding: 10px 14px;
  background: var(--mnl-accent);
  color: #111;
  border-radius: 10px;
  font-weight: 700;
}

.manantial-theme .skip-link:focus {
  top: 12px;
}

/* =========================================================
   HEADER DESKTOP / GENERAL
   ---------------------------------------------------------
   AQUÍ ESTÁN LOS CAMBIOS NUEVOS PRINCIPALES:
   - header sticky
   - fondo más sólido
   - blur
   - línea inferior
   - sombra suave
   ========================================================= */
.manantial-theme .site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.94); /* antes 0.92, ahora un poco más sólido */
  backdrop-filter: blur(16px); /* efecto vidrio / blur */
  border-bottom: 1px solid rgba(10, 21, 48, 0.08);
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05); /* NUEVO: sombra suave para separar del contenido */
}

/* Contenedor interno del header */
.manantial-theme .header-inner {
  min-height: var(--mnl-header-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px; /* NUEVO: gap ligeramente más compacto que antes */
}

/* =========================================================
   BLOQUE NUEVO PARA MÓVIL
   ---------------------------------------------------------
   En escritorio lo dejamos como "contents" para que no altere
   la estructura visual.
   En móvil sí se usa como fila superior.
   ========================================================= */
.manantial-theme .header-top-mobile {
  display: contents;
}

/* Marca / logo + nombre */
.manantial-theme .brand {
  display: inline-flex;
  align-items: center;
  gap: 10px; /* NUEVO: un poco más pegado */
  color: var(--mnl-text-dark);
  font-weight: 800;
  letter-spacing: -0.02em;
  flex-shrink: 0; /* NUEVO: evita que el logo se encoja */
}

/* Hover del nombre de marca */
.manantial-theme .brand:hover .brand-name {
  color: var(--mnl-accent);
}

/* Logo */
.manantial-theme .brand img {
  width: 48px; /* NUEVO: un poco más pequeño que antes */
  height: 48px;
  object-fit: contain;
}

/* Nombre de marca */
.manantial-theme .brand-name {
  font-size: 1.75rem; /* NUEVO: ligeramente reducido */
  line-height: 1;
  transition: color 0.25s ease;
}

/* =========================================================
   NAVEGACIÓN PRINCIPAL
   ---------------------------------------------------------
   Se ajusta para que quede más cerca del logo.
   ========================================================= */
.manantial-theme .main-nav {
  margin-left: -6px; /* NUEVO: acerca visualmente el menú hacia el logo */
}

.manantial-theme .main-nav ul {
  list-style: none;
  display: flex;
  align-items: center;
  gap: 28px; /* antes era más amplio, ahora más compacto */
  margin: 0;
  padding: 0;
}

.manantial-theme .main-nav a {
  position: relative;
  display: inline-block;
  color: var(--mnl-text-dark);
  font-weight: 700;
  font-size: 1rem; /* ligeramente más controlado */
  padding: 6px 0; /* NUEVO: zona de clic un poco mejor */
}

/* Línea amarilla animada bajo cada link */
.manantial-theme .main-nav a::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -4px; /* NUEVO: más pegado al texto */
  width: 100%;
  height: 3px;
  border-radius: 999px;
  background: var(--mnl-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.25s ease;
}

.manantial-theme .main-nav a:hover::after,
.manantial-theme .main-nav a:focus-visible::after {
  transform: scaleX(1);
}

/* =========================================================
   BOTÓN CTA DEL HEADER
   ---------------------------------------------------------
   Ahora queda mejor alineado y con gradiente azul.
   ========================================================= */
.manantial-theme .header-cta {
  display: flex;
  align-items: center;
  margin-left: auto; /* NUEVO: empuja el botón hacia la derecha */
}

.manantial-theme .call-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, #2d63ef 0%, #245be8 100%); /* NUEVO: gradiente */
  color: #fff;
  padding: 13px 20px; /* ajustado */
  border-radius: 16px; /* más redondeado */
  font-weight: 800;
  box-shadow: 0 12px 28px rgba(36, 91, 232, 0.24); /* sombra más refinada */
  white-space: nowrap; /* evita que el texto se parta */
}

.manantial-theme .call-btn:hover {
  background: linear-gradient(135deg, #2252d4 0%, #1d49bc 100%);
  color: #fff;
  transform: translateY(-1px);
}

/* Si usas íconos Font Awesome con <i> */
.manantial-theme .call-btn i {
  font-size: 0.95rem;
}

/* Mantengo también compatibilidad si alguna vez usas svg */
.manantial-theme .call-btn svg {
  width: 20px;
  height: 20px;
}

/* =========================================================
   FOOTER
   ---------------------------------------------------------
   Desde aquí hacia abajo no cambio estructura, solo comento.
   ========================================================= */
.manantial-theme .site-footer {
  background:
    radial-gradient(circle at top left, rgba(255, 212, 0, 0.08), transparent 24%),
    linear-gradient(180deg, #061125 0%, #07162c 100%);
  color: var(--mnl-text);
  padding-top: 72px;
}

.manantial-theme .footer-grid {
  display: grid;
  grid-template-columns: 1.25fr 0.85fr 0.8fr;
  gap: 64px;
  align-items: start;
}

.manantial-theme .footer-brand-col h2 {
  margin: 24px 0 18px;
  font-size: clamp(1.8rem, 2vw, 2.5rem);
  line-height: 1.15;
  letter-spacing: -0.03em;
}

.manantial-theme .footer-brand-col p {
  margin: 0;
  max-width: 620px;
  color: var(--mnl-text-soft);
  font-size: 1.02rem;
  line-height: 1.75;
}

.manantial-theme .footer-brand img {
  width: 64px;
  height: 64px;
}

.manantial-theme .social-block {
  margin-top: 28px;
}

.manantial-theme .social-block > span {
  display: inline-block;
  margin-bottom: 16px;
  font-weight: 700;
