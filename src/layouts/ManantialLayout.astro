---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Gasfitería en Arequipa | Instalación y Servicios Manantial',
  description = 'Gasfitería en Arequipa con atención inmediata 24/7. Destapes de desagüe, detección de fugas, instalaciones sanitarias, trampas de grasa y enchapado. Servicio rápido y garantizado.',
  canonical,
  ogImage = '/images/og/og-manantial.jpg',
  noindex = false,
} = Astro.props;

const siteName = 'Instalación y Servicios Manantial';
const baseUrl = Astro.site ? new URL(Astro.site).origin : '';
const canonicalUrl = canonical
  ? new URL(canonical, baseUrl || 'http://localhost:4321').toString()
  : Astro.url?.href;

const finalOgImage = ogImage?.startsWith('http')
  ? ogImage
  : `${baseUrl}${ogImage}`;

const navItems = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#contacto', label: 'Contacto' },
];

const phoneDisplay = '970 706 965';
const phoneRaw = '51970706965';
const whatsappHref = `https://wa.me/${phoneRaw}`;
---

<!doctype html>
<html lang="es-PE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a1530" />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {finalOgImage && <meta property="og:image" content={finalOgImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {finalOgImage && <meta name="twitter:image" content={finalOgImage} />}

    <link rel="icon" type="image/png" href="/images/logo-manantial.png" />

    <link rel="stylesheet" href="/css/base.css" />
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
/>




    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: siteName,
      description,
      areaServed: 'Arequipa, Perú',
      telephone: '+51 970 706 965',
      image: finalOgImage,
      url: canonicalUrl || undefined,
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Arequipa',
        addressCountry: 'PE'
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: [
            'Monday',
            'Tuesday',
            'Wednesday',
            'Thursday',
            'Friday',
            'Saturday',
            'Sunday'
          ],
          opens: '00:00',
          closes: '23:59'
        }
      ]
    })} />
  </head>



  <body>
  <div class="manantial-theme">
    <a class="skip-link" href="#contenido">Saltar al contenido</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand" aria-label="Ir al inicio de Instalación y Servicios Manantial">
          <img
            src="/assets/logo-personita.png"
            alt="Logo de Instalación y Servicios Manantial"
            width="52"
            height="52"
            loading="eager"
            decoding="async"
          />
          <span class="brand-name">Manantial</span>
        </a>

        <nav class="main-nav" aria-label="Navegación principal">
          <ul>
            {navItems.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="header-cta">
          <a class="call-btn" href={`tel:+${phoneRaw}`} aria-label={`Llamar al ${phoneDisplay}`}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24a11.36 11.36 0 0 0 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.49a1 1 0 0 1 1 1a11.36 11.36 0 0 0 .57 3.57a1 1 0 0 1-.24 1Z"
              />
            </svg>
            <span>{phoneDisplay}</span>
          </a>
        </div>
      </div>
    </header>

    <main id="contenido">
      <slot />
    </main>

    <footer class="site-footer" id="contacto">
      <div class="container footer-grid">
        <div class="footer-brand-col">
          <a href="/" class="footer-brand" aria-label="Ir al inicio">
            <img
              src="/images/logo-manantial.png"
              alt="Logo de Instalación y Servicios Manantial"
              width="64"
              height="64"
              loading="lazy"
              decoding="async"
            />
          </a>

          <h2>Instalación y Servicios Manantial</h2>
          <p>
            Más de 10 años brindando soluciones profesionales en gasfitería y
            enchapado. Tu socio confiable para cualquier proyecto, grande o pequeño.
          </p>

          <div class="social-block">
            <span>Síguenos en:</span>

            <div class="social-links">
              <a href="#" aria-label="Facebook">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M13.5 8H15V5h-1.5C10.46 5 9 6.79 9 9.5V11H7v3h2v5h3v-5h2.11l.39-3H12V9.5c0-.86.14-1.5 1.5-1.5Z"
                  />
                </svg>
              </a>

              <a href="#" aria-label="Instagram">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3Zm5 3.5A4.5 4.5 0 1 1 7.5 12A4.51 4.51 0 0 1 12 7.5Zm0 2A2.5 2.5 0 1 0 14.5 12A2.5 2.5 0 0 0 12 9.5Zm4.75-3.25a1.25 1.25 0 1 1-1.25 1.25a1.25 1.25 0 0 1 1.25-1.25Z"
                  />
                </svg>
              </a>

              <a href="#" aria-label="X o Twitter">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M18.9 2H22l-6.77 7.74L23.2 22h-6.26l-4.9-6.42L6.42 22H3.3l7.24-8.28L1 2h6.42l4.43 5.86ZM17.8 20h1.73L6.48 3.9H4.62Z"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <div class="footer-services-col" id="servicios">
          <h3>Nuestros Servicios</h3>
          <ul>
            <li><a href="/#servicios">Detección de Fugas de Agua</a></li>
            <li><a href="/#servicios">Desatoro de Tuberías</a></li>
            <li><a href="/#servicios">Limpieza de Trampas de Grasa</a></li>
            <li><a href="/#servicios">Enchapado de Mayólica</a></li>
            <li><a href="/#servicios">Gasfitería en General</a></li>
            <li><a href={whatsappHref} target="_blank" rel="noopener noreferrer">Servicio de Emergencia 24/7</a></li>
          </ul>
        </div>

        <div class="footer-contact-col">
          <h3>Contacto</h3>

          <div class="contact-list">
            <div class="contact-item">
              <div class="icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24a11.36 11.36 0 0 0 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.49a1 1 0 0 1 1 1a11.36 11.36 0 0 0 .57 3.57a1 1 0 0 1-.24 1Z"
                  />
                </svg>
              </div>

              <div>
                <a href="tel:+51970706965">970 706 965</a>
                <a href="tel:+51988970791">988 970 791</a>
                <a href="tel:+51925384411">925 384 411</a>
              </div>
            </div>

            <div class="contact-item">
              <div class="icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M12 1.75A10.25 10.25 0 1 0 22.25 12A10.26 10.26 0 0 0 12 1.75Zm1 10.66V6.75h-2v6.5l4.5 2.67l1-1.68Z"
                  />
                </svg>
              </div>

              <div>
                <strong>Horario de Atención</strong>
                <p>Lun - Dom: 24 horas</p>
                <span class="available">¡Siempre disponibles!</span>
              </div>
            </div>

            <div class="contact-item">
              <div class="icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M12 2a7 7 0 0 0-7 7c0 4.88 5.53 11.56 6.16 12.31a1.09 1.09 0 0 0 1.68 0C13.47 20.56 19 13.88 19 9a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 14.5 9A2.5 2.5 0 0 1 12 11.5Z"
                  />
                </svg>
              </div>

              <div>
                <strong>Zona de Servicio</strong>
                <p>Arequipa y alrededores</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>© 2026 Instalación y Servicios Manantial. Todos los derechos reservados.</p>

        <nav class="footer-nav" aria-label="Navegación secundaria">
          <a href="/#nosotros">Sobre Nosotros</a>
          <a href="/#servicios">Servicios</a>
          <a href="/#contacto">Contacto</a>
        </nav>
      </div>
    </footer>
  </div>

  <style>
    .manantial-theme {
      --mnl-bg: #081327;
      --mnl-bg-soft: #0c1a35;
      --mnl-bg-card: rgba(255, 255, 255, 0.08);
      --mnl-surface: #ffffff;
      --mnl-text: #ffffff;
      --mnl-text-soft: rgba(255, 255, 255, 0.78);
      --mnl-text-dark: #14213d;
      --mnl-border: rgba(255, 255, 255, 0.1);
      --mnl-border-soft: rgba(255, 255, 255, 0.07);
      --mnl-primary: #245be8;
      --mnl-primary-hover: #1b49bc;
      --mnl-accent: #ffd400;
      --mnl-accent-2: #ffea70;
      --mnl-success: #00d26a;
      --mnl-shadow: 0 12px 38px rgba(0, 0, 0, 0.25);
      --mnl-radius: 20px;
      --mnl-radius-sm: 14px;
      --mnl-container: 1200px;
      --mnl-header-h: 82px;
      color: var(--mnl-text-dark);
      background: var(--mnl-surface);
      min-height: 100vh;
    }

    .manantial-theme,
    .manantial-theme * {
      box-sizing: border-box;
    }

    .manantial-theme img {
      max-width: 100%;
      display: block;
    }

    .manantial-theme a {
      color: inherit;
      text-decoration: none;
      transition:
        color 0.25s ease,
        background-color 0.25s ease,
        border-color 0.25s ease,
        transform 0.25s ease,
        opacity 0.25s ease;
    }

    .manantial-theme a:hover {
      color: var(--mnl-accent);
    }

    .manantial-theme main {
      min-height: 45vh;
    }

    .manantial-theme .container {
      width: min(100% - 40px, var(--mnl-container));
      margin-inline: auto;
    }

    .manantial-theme .skip-link {
      position: absolute;
      left: 12px;
      top: -44px;
      z-index: 999;
      padding: 10px 14px;
      background: var(--mnl-accent);
      color: #111;
      border-radius: 10px;
      font-weight: 700;
    }

    .manantial-theme .skip-link:focus {
      top: 12px;
    }

    .manantial-theme .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(10, 21, 48, 0.08);
    }

    .manantial-theme .header-inner {
      min-height: var(--mnl-header-h);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .manantial-theme .brand {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      color: var(--mnl-text-dark);
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .manantial-theme .brand:hover .brand-name {
      color: var(--mnl-accent);
    }

    .manantial-theme .brand img {
      width: 52px;
      height: 52px;
      object-fit: contain;
    }

    .manantial-theme .brand-name {
      font-size: 1.9rem;
      line-height: 1;
      transition: color 0.25s ease;
    }

    .manantial-theme .main-nav ul {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 34px;
      margin: 0;
      padding: 0;
    }

    .manantial-theme .main-nav a {
      position: relative;
      display: inline-block;
      color: var(--mnl-text-dark);
      font-weight: 700;
      font-size: 1.05rem;
    }

    .manantial-theme .main-nav a::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -8px;
      width: 100%;
      height: 3px;
      border-radius: 999px;
      background: var(--mnl-accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }

    .manantial-theme .main-nav a:hover::after,
    .manantial-theme .main-nav a:focus-visible::after {
      transform: scaleX(1);
    }

    .manantial-theme .header-cta {
      display: flex;
      align-items: center;
    }

    .manantial-theme .call-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--mnl-primary);
      color: #fff;
      padding: 14px 22px;
      border-radius: 14px;
      font-weight: 800;
      box-shadow: 0 10px 28px rgba(36, 91, 232, 0.28);
    }

    .manantial-theme .call-btn:hover {
      background: var(--mnl-primary-hover);
      color: #fff;
      transform: translateY(-1px);
    }

    .manantial-theme .call-btn svg {
      width: 20px;
      height: 20px;
    }

    .manantial-theme .site-footer {
      background:
        radial-gradient(circle at top left, rgba(255, 212, 0, 0.08), transparent 24%),
        linear-gradient(180deg, #061125 0%, #07162c 100%);
      color: var(--mnl-text);
      padding-top: 72px;
    }

    .manantial-theme .footer-grid {
      display: grid;
      grid-template-columns: 1.25fr 0.85fr 0.8fr;
      gap: 64px;
      align-items: start;
    }

    .manantial-theme .footer-brand-col h2 {
      margin: 24px 0 18px;
      font-size: clamp(1.8rem, 2vw, 2.5rem);
      line-height: 1.15;
      letter-spacing: -0.03em;
    }

    .manantial-theme .footer-brand-col p {
      margin: 0;
      max-width: 620px;
      color: var(--mnl-text-soft);
      font-size: 1.02rem;
      line-height: 1.75;
    }

    .manantial-theme .footer-brand img {
      width: 64px;
      height: 64px;
    }

    .manantial-theme .social-block {
      margin-top: 28px;
    }

    .manantial-theme .social-block > span {
      display: inline-block;
      margin-bottom: 16px;
      font-weight: 700;
    }

    .manantial-theme .social-links {
      display: flex;
      gap: 12px;
    }

    .manantial-theme .social-links a {
      width: 50px;
      height: 50px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.09);
      border: 1px solid var(--mnl-border);
      border-radius: 12px;
      color: #fff;
    }

    .manantial-theme .social-links a:hover {
      color: #111;
      background: var(--mnl-accent);
      border-color: var(--mnl-accent);
      transform: translateY(-2px);
    }

    .manantial-theme .social-links svg {
      width: 22px;
      height: 22px;
    }

    .manantial-theme .footer-services-col h3,
    .manantial-theme .footer-contact-col h3 {
      margin: 0 0 22px;
      color: var(--mnl-accent);
      font-size: 1.9rem;
      line-height: 1.15;
      letter-spacing: -0.03em;
    }

    .manantial-theme .footer-services-col ul {
      list-style: disc;
      margin: 0;
      padding-left: 22px;
    }

    .manantial-theme .footer-services-col li {
      margin-bottom: 16px;
      color: var(--mnl-text-soft);
      line-height: 1.45;
    }

    .manantial-theme .footer-services-col a:hover {
      color: var(--mnl-accent);
    }

    .manantial-theme .contact-list {
      display: grid;
      gap: 26px;
    }

    .manantial-theme .contact-item {
      display: grid;
      grid-template-columns: 20px 1fr;
      gap: 14px;
      align-items: start;
    }

    .manantial-theme .contact-item .icon {
      color: var(--mnl-accent);
      margin-top: 2px;
    }

    .manantial-theme .contact-item .icon svg {
      width: 20px;
      height: 20px;
    }

    .manantial-theme .contact-item strong {
      display: block;
      margin-bottom: 6px;
      font-size: 1.35rem;
      line-height: 1.15;
    }

    .manantial-theme .contact-item p,
    .manantial-theme .contact-item span,
    .manantial-theme .contact-item a {
      display: block;
      color: var(--mnl-text-soft);
      font-size: 1rem;
      line-height: 1.45;
      margin: 0;
    }

    .manantial-theme .contact-item a + a {
      margin-top: 6px;
    }

    .manantial-theme .available {
      color: var(--mnl-success) !important;
      font-weight: 800;
      margin-top: 2px !important;
    }

    .manantial-theme .footer-bottom {
      margin-top: 56px;
      padding: 26px 0 34px;
      border-top: 1px solid var(--mnl-border-soft);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
    }

    .manantial-theme .footer-bottom p {
      margin: 0;
      color: var(--mnl-text-soft);
    }

    .manantial-theme .footer-nav {
      display: flex;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
    }

    .manantial-theme .footer-nav a {
      color: var(--mnl-text-soft);
    }

    .manantial-theme .footer-nav a:hover {
      color: var(--mnl-accent);
    }

    .manantial-theme .text-accent,
    .manantial-theme .word-highlight {
      color: var(--mnl-accent);
      transition: color 0.25s ease;
    }

    .manantial-theme .hover-yellow:hover,
    .manantial-theme .hover-yellow:focus-visible {
      color: var(--mnl-accent) !important;
    }

    @media (max-width: 1080px) {
      .manantial-theme .header-inner {
        gap: 18px;
      }

      .manantial-theme .main-nav ul {
        gap: 22px;
      }

      .manantial-theme .brand-name {
        font-size: 1.55rem;
      }

      .manantial-theme .footer-grid {
        grid-template-columns: 1fr;
        gap: 42px;
      }

      .manantial-theme .footer-brand-col p {
        max-width: 100%;
      }
    }

    @media (max-width: 820px) {
      .manantial-theme .site-header {
        position: static;
      }

      .manantial-theme .header-inner {
        padding: 16px 0;
        min-height: auto;
        flex-wrap: wrap;
      }

      .manantial-theme .brand {
        width: 100%;
      }

      .manantial-theme .main-nav {
        order: 3;
        width: 100%;
      }

      .manantial-theme .main-nav ul {
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 16px 20px;
      }

      .manantial-theme .header-cta {
        margin-left: auto;
      }

      .manantial-theme .call-btn {
        padding: 12px 18px;
      }
    }

    @media (max-width: 560px) {
      .manantial-theme .container {
        width: min(100% - 28px, var(--mnl-container));
      }

      .manantial-theme .brand-name {
        font-size: 1.35rem;
      }

      .manantial-theme .call-btn span {
        font-size: 0.95rem;
      }

      .manantial-theme .footer-services-col h3,
      .manantial-theme .footer-contact-col h3 {
        font-size: 1.55rem;
      }

      .manantial-theme .footer-brand-col h2 {
        font-size: 1.7rem;
      }

      .manantial-theme .footer-bottom {
        flex-direction: column;
        align-items: flex-start;
      }

      .manantial-theme .footer-nav {
        gap: 18px;
      }
    }
  </style>
</body>















</html>