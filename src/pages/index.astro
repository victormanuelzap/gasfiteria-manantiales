---
import ManantialLayout from "../layouts/ManantialLayout.astro";

import TrabajosGallery from "../components/TrabajosGallery.astro";

---

<ManantialLayout
  title="Gasfitero en Arequipa | Instalación y Servicios Manantial"
  description="Gasfitería y enchapado profesional en Arequipa. Detección de fugas, desatoros, trampas de grasa, instalaciones sanitarias y enchapado."
>
  <!-- SECTION: HERO PRINCIPAL -->
<section class="mn-hero">
  <!-- fondo base real -->
  <picture class="mn-hero__bg-picture" aria-hidden="true">
    <source
      srcset="/assets/fondo_hero_pc.webp"
      media="(min-width: 901px)"
    />
    <img
      src="/assets/fondo_hero_pc.webp"
      alt=""
      class="mn-hero__bg-image"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <!-- lona azul / capa desvanecida -->
  <div class="mn-hero__overlay"></div>

  <!-- brillos -->
  <div class="mn-hero__glow mn-hero__glow--one"></div>
  <div class="mn-hero__glow mn-hero__glow--two"></div>

  <div class="container mn-hero__grid">
    <div class="mn-hero__content">
      <div class="mn-hero__logo-wrap">
        <img
          src="/assets/logo-personita.png"
          alt="Logo Instalación y Servicios Manantial"
          class="mn-hero__logo"
        />
      </div>

      <span class="mn-hero__eyebrow">
        <i class="fa-solid fa-wrench"></i>
        Gasfitero profesional en Arequipa
      </span>

      <h1 class="mn-hero__title">
        Instalación y
        <span class="text-yellow">Servicios Manantial</span>
      </h1>

      <p class="mn-hero__text">
        Gasfitero y Enchapador Profesional en Arequipa. Servicios de gasfitería para toda la ciudad.
      </p>

      <div class="mn-hero__actions">
        <a href="tel:+51970706965" class="btn btn--yellow">
          <i class="fa-solid fa-phone"></i>
          Llamar Ahora
        </a>

        <a href="#servicios" class="btn btn--outline-light">
          Ver Servicios
        </a>
      </div>

      <div class="mn-hero__features">
        <div class="mn-hero__feature">
          <i class="fa-regular fa-clock"></i>
          <span>Atención 24/7</span>
        </div>
        <div class="mn-hero__feature">
          <i class="fa-solid fa-location-dot"></i>
          <span>Todo Arequipa</span>
        </div>
        <div class="mn-hero__feature">
          <i class="fa-solid fa-shield-halved"></i>
          <span>Trabajo garantizado</span>
        </div>
      </div>

      <div class="mn-hero__badge">
        <i class="fa-solid fa-bolt"></i>
        <span>Servicio de emergencia disponible 24/7</span>
      </div>
    </div>

    <div class="mn-hero__image">
      <div class="mn-hero__image-wrap">
        <img
          src="/assets/seo-gasfitero.webp"
          alt="Gasfitero profesional de Instalación y Servicios Manantial"
          class="mn-hero__worker"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>









<!-- SECTION: SERVICIOS --><!-- SECTION: SERVICIOS -->
<!-- SECTION: SERVICIOS -->
<section class="mn-services section" id="servicios">
